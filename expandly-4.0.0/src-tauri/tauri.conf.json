{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "Expandly",
  "productName": "Expandly",
  "version": "4.0.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Expandly 4.0.0",
        "width": 950,
        "height": 700,
        "minWidth": 900,
        "minHeight": 450,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Expandly",
        "width": 400,
        "height": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}